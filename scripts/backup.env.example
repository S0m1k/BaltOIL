# BaltOIL cloud backup configuration
# Copy to scripts/backup.env and fill in to enable cloud sync.
# Keep backup.env out of git (it's in .gitignore).
#
# If BACKUP_CLOUD_PROVIDER is empty or this file doesn't exist,
# cloud sync is silently skipped — local backups still run normally.

BACKUP_CLOUD_PROVIDER=        # s3 | yandex | selectel | (empty = disabled)
BACKUP_CLOUD_BUCKET=          # e.g. baltoil-backups
BACKUP_CLOUD_ENDPOINT=        # e.g. https://storage.yandexcloud.net (for Yandex)
BACKUP_CLOUD_ACCESS_KEY=
BACKUP_CLOUD_SECRET_KEY=
