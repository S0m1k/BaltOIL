# Shell-скрипты ВСЕГДА с LF: иначе на Windows-checkout git подставляет CRLF,
# и в Linux-контейнере падает `/bin/bash^M: bad interpreter` (ломался postgres-init).
*.sh        text eol=lf
entrypoint.sh text eol=lf

# Прочие текстовые файлы — нормализуем переносы в репозитории к LF.
*.py        text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.ini       text eol=lf
Dockerfile  text eol=lf

# Бинарники — не трогать.
*.pdf       binary
*.png       binary
*.jpg       binary
*.xls       binary
*.xlsx      binary
*.doc       binary
*.docx      binary
