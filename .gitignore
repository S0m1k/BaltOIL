# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
dist/
build/

# Env files — contain secrets, never commit
*.env
.env.*

# DB / data volumes
*.db
*.sqlite

# TLS certs (self-signed для локального dev; на проде монтируются извне)
tls/

