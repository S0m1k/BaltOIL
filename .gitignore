*/media/
media/

# Alembic migration auto-generated (keep versions folder but not pycache)
*/migrations/versions/__pycache__/

# Docker / compose overrides
docker-compose.override.yml

# IDE
.idea/
.vscode/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
.claude/

# Claude Code personal working context — not project documentation
CLAUDE.md

